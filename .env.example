# Azure OpenAI Configuration
# Copy this file to .env and fill in your actual Azure OpenAI credentials

# The name of your Azure OpenAI deployment (e.g., "gpt-4-turbo" or "gpt-4o")
AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your_api_key_here

# The base URL of your Azure OpenAI resource (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your_resource_name.openai.azure.com/

# The API version to use (e.g., "2024-10-21" or "2024-08-01-preview")
AZURE_OPENAI_API_VERSION=2024-10-21

# -----------------------------------------------------------------------
# Sub-LM Deployment (optional)
# Use a cheaper model (e.g., gpt-4o-mini) to reduce costs on large documents.
# Shares the same endpoint, API key, and API version as main LM.
# If not specified, falls back to main LM deployment.
# -----------------------------------------------------------------------

# The name of your Azure OpenAI sub-LM deployment (e.g., "gpt-4o-mini" or "gpt-35-turbo")
AZURE_OPENAI_SUB_LM_DEPLOYMENT=your_sub_deployment_name
